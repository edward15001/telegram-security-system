# ============================================
# CONFIGURACIÓN DEL SISTEMA DE CIBERSEGURIDAD
# ============================================

# ----------------
# Telegram Bot
# ----------------
# Token del bot de Telegram (obtenerlo de @BotFather)
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI

# Chat ID donde se enviarán las alertas críticas de red de Suricata
# Para obtenerlo: envía un mensaje al bot y usa /estado, o usa @userinfobot
# Déjalo en 0 para desactivar las alertas de red por Telegram
TELEGRAM_ALERT_CHAT_ID=0

# ----------------
# MongoDB
# ----------------
# URI de conexión a MongoDB (usar el servicio interno de Docker)
MONGO_URI=mongodb://mongodb:27017/ciberseguridad

# ----------------
# Ollama (IA)
# ----------------
# Host de Ollama (usar el servicio interno de Docker)
OLLAMA_HOST=http://ollama:11434

# Modelo de IA a utilizar
# Opciones: mistral:7b-instruct, llama2:13b, phi:latest
OLLAMA_MODEL=mistral:7b-instruct

# ----------------
# Configuración General
# ----------------
# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Umbral de amenaza (0-100) - Mensajes con score mayor serán clasificados como amenaza
THREAT_THRESHOLD=70

# ----------------
# Configuración de Suricata
# ----------------
# Interfaz de red a monitorear (cambiar según tu configuración)
SURICATA_INTERFACE=eth0